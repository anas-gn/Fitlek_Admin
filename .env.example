# Copy this file to .env.local and fill in your real values

# MySQL / MariaDB connection (matches the fitlekdb schema)
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=fitlekdb

# Secret used to sign admin session tokens (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret

# Session cookie lifetime in hours
SESSION_HOURS=12
